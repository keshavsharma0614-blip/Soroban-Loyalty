# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for Soroban Loyalty Platform
#
# Copy this file to .env and fill in the values.
# Variables marked REQUIRED must be set before the app will start.
# Variables marked OPTIONAL fall back to the shown default when omitted.
# Variables marked SECRET must NEVER be committed to version control.
#   In production, load them from AWS Secrets Manager, Doppler, or
#   GitHub Actions secrets — see docs/deployment-guide.md#secrets-management.
# ─────────────────────────────────────────────────────────────────────────────

# ── Soroban RPC ───────────────────────────────────────────────────────────────
# REQUIRED — Soroban JSON-RPC endpoint
SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc

# REQUIRED — Stellar network passphrase
# Local:    "Standalone Network ; February 2017"
# Testnet:  "Test SDF Network ; September 2015"
# Mainnet:  "Public Global Stellar Network ; September 2015"
NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# ── Database ──────────────────────────────────────────────────────────────────
# SECRET — contains password; load from secrets manager in production
# REQUIRED (unless DB_SECRET_ARN is set and secrets.ts populates it at runtime)
DATABASE_URL=postgres://loyalty:CHANGE_ME@localhost:5432/soroban_loyalty

# ── Redis ─────────────────────────────────────────────────────────────────────
# OPTIONAL — Redis connection URL (may contain password — treat as SECRET)
REDIS_URL=redis://localhost:6379

# ── AWS Secrets Manager ───────────────────────────────────────────────────────
# OPTIONAL — ARN or name of the JSON secret containing DB credentials and
#            contract IDs. When set, secrets.ts loads values into process.env
#            before env validation runs.
SECRETS_ARN=

# OPTIONAL — AWS region for Secrets Manager. Default: us-east-1
AWS_REGION=us-east-1

# ── Deployed contract IDs ─────────────────────────────────────────────────────
# REQUIRED — fill in after deploying contracts
REWARDS_CONTRACT_ID=
CAMPAIGN_CONTRACT_ID=
TOKEN_CONTRACT_ID=

# ── Backend server ────────────────────────────────────────────────────────────
# OPTIONAL — HTTP port. Default: 3001
PORT=3001

# OPTIONAL — Set to "false" to disable the on-chain event indexer. Default: true
ENABLE_INDEXER=true

# ── JWT / Auth ────────────────────────────────────────────────────────────────
# SECRET — used to sign session tokens; generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_HEX_32

# ── Alerting ──────────────────────────────────────────────────────────────────
# SECRET — Slack Incoming Webhook URL for #alerts channel
SLACK_WEBHOOK_URL=

# OPTIONAL — Set to "true" to suppress alerts during maintenance windows. Default: false
MAINTENANCE_MODE=false

# ── PostgreSQL Backups ────────────────────────────────────────────────────────
# REQUIRED for backup CronJob — S3 bucket name for pg_dump archives
S3_BACKUP_BUCKET=soroban-loyalty-production-db-backups

# OPTIONAL — IAM role ARN bound to the backup ServiceAccount via IRSA
BACKUP_IAM_ROLE_ARN=

# ── Monitoring ────────────────────────────────────────────────────────────────
# SECRET — Grafana admin password; change before production deployment
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# ── Sentry Error Monitoring ───────────────────────────────────────────────────
# SECRET — DSN from https://sentry.io
SENTRY_DSN=
# Exposed to the browser for client-side error capture
NEXT_PUBLIC_SENTRY_DSN=
# SECRET — Required for source map uploads during CI/CD build
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── SSL / TLS ─────────────────────────────────────────────────────────────────
# Domain for Let's Encrypt certificate (apex + wildcard)
DOMAIN=soroban-loyalty.example.com

# OPTIONAL — Email for ACME account registration and expiry notices
ACME_EMAIL=ops@example.com

# ── Frontend (Next.js public vars) ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SOROBAN_RPC_URL=http://localhost:8000/soroban/rpc
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"
NEXT_PUBLIC_REWARDS_CONTRACT_ID=
NEXT_PUBLIC_CAMPAIGN_CONTRACT_ID=
